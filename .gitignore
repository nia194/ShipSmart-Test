# ─── Byte-compiled / cache ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so

# ─── Virtual env ──────────────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.uv/

# ─── Distribution / packaging ─────────────────────────────────────────────────
build/
dist/
*.egg
*.egg-info/
.eggs/
wheels/
pip-wheel-metadata/

# ─── Test / coverage ──────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover

# ─── Type checkers / linters ──────────────────────────────────────────────────
.mypy_cache/
.pyre/
.pytype/
.ruff_cache/

# ─── e2e stack state (scripts/run-stack.sh) ───────────────────────────────────
# Per-run service logs + PID files for the locally-hosted MCP/API/Java stack.
.stack/

# ─── Eval run outputs (evals/runners/run_lane.py) ─────────────────────────────
# The append-only history, regenerated trend, and per-run traces are generated
# artifacts (CI regenerates them); the reports/ dir is kept via .gitkeep.
evals/reports/history.jsonl
evals/reports/trend.md
evals/reports/traces/

# ─── Env / Secrets ────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── IDE ──────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

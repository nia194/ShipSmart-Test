# ShipSmart-Test (cross-repo contract + live e2e tests) - environment variables
#
# These are OPTIONAL overrides. With nothing set, the suite uses the defaults
# below, which match the stack hosted by scripts/run-stack.sh — so
# `uv run pytest` works with zero config. The contract/ tests need no env at all.
#
# NOTE: the tests read these via os.getenv (see e2e/conftest.py); there is no
# dotenv auto-loader. To use this file, export the values into your shell first:
#
#     set -a && source .env && set +a
#     uv run pytest e2e/
#
# Copy to .env and adjust only if you host the services on other endpoints.

# ─── e2e target endpoints (where the live stack is reachable) ─────────────────
SHIPSMART_E2E_MCP_URL=http://127.0.0.1:8001
SHIPSMART_E2E_API_URL=http://127.0.0.1:8000
SHIPSMART_E2E_JAVA_URL=http://127.0.0.1:8080

# ─── Shared test JWT secret (HS256, >=32 bytes) ───────────────────────────────
# Non-secret, test-only. Must match the secret the hosted Java service verifies
# with — scripts/run-stack.sh exports this same value as SUPABASE_JWT_SECRET. If
# you change it here, update run-stack.sh (or your Java config) to match, or the
# Java e2e tests will get 401s.
SHIPSMART_E2E_JWT_SECRET=e2e-test-secret-please-change-32chars-minimum
